{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/backbiten/Legacy64/schemas/artifact.schema.json",
  "title": "Artifact Record",
  "description": "Metadata record for an artifact stored in the Legacy64 content-addressed object store",
  "type": "object",
  "required": ["id", "lane", "type", "filename", "sha256", "size", "imported_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique artifact identifier (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "lane": {
      "type": "string",
      "description": "Preservation lane: legacy64 (AMD64) or legacy32 (x86)",
      "enum": ["legacy64", "legacy32"]
    },
    "type": {
      "type": "string",
      "description": "Artifact type classification",
      "enum": ["bin", "src", "firmware", "doc"]
    },
    "filename": {
      "type": "string",
      "description": "Original filename at time of import",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "description": "SHA-256 hex digest of the artifact content",
      "pattern": "^[0-9a-f]{64}$"
    },
    "size": {
      "type": "integer",
      "description": "File size in bytes",
      "minimum": 0
    },
    "imported_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the artifact was imported",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "description": "Human-readable artifact name"
    },
    "version": {
      "type": "string",
      "description": "Version string (e.g. 1.0.0, 20040501)"
    },
    "description": {
      "type": "string",
      "description": "Free-form description of the artifact"
    },
    "source_url": {
      "type": "string",
      "description": "Original source URL or acquisition path",
      "format": "uri"
    },
    "tags": {
      "type": "array",
      "description": "Optional searchable tags",
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
